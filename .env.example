# ============================================
# SOLANA MEMECOIN SNIPER BOT - Environment Config
# Copy this file to .env and fill in your values
# ============================================

# --- Telegram Bot ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Solana RPC ---
# Use a fast dedicated RPC (Helius, QuickNode, Triton) for best performance
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# --- Helius API (recommended for new pool detection) ---
HELIUS_API_KEY=your_helius_api_key_here

# --- Photon API ---
PHOTON_API_URL=https://api.photon-sol.tinyastro.io
PHOTON_API_KEY=your_photon_api_key_here

# --- Jupiter Aggregator (fallback swap router) ---
JUPITER_API_URL=https://quote-api.jup.ag/v6

# --- Encryption Key for Wallet Storage ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# --- Database ---
DB_PATH=./data/sniper.db

# --- Default Risk Parameters ---
DEFAULT_POSITION_SIZE_SOL=0.1
DEFAULT_STOP_LOSS_PERCENT=50
DEFAULT_TAKE_PROFIT_PERCENT=300
DEFAULT_MAX_DAILY_LOSS_SOL=1.0
DEFAULT_MAX_OPEN_POSITIONS=3

# --- Sniping Config ---
MIN_POOL_LIQUIDITY_SOL=10
MAX_SLIPPAGE_BPS=500
PRIORITY_FEE_MICROLAMPORTS=100000

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=./logs/bot.log
